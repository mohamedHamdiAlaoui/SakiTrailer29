# Frontend Firebase Web SDK (Google OAuth popup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional: use an absolute backend URL in production.
# Leave empty for Vite dev proxy (/api -> VITE_AUTH_API_TARGET).
VITE_API_BASE_URL=
VITE_AUTH_API_TARGET=http://localhost:4000

# Backend API settings
AUTH_API_PORT=4000
# Comma-separated list supported, e.g. http://localhost:5173,https://your-site.netlify.app
AUTH_API_ALLOWED_ORIGIN=http://localhost:5173
PRODUCTS_DB_PATH=./server/data/sakitrailer29.sqlite
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=SAKI TRAILER 29 Admin

# Firebase Admin SDK credentials (Service Account)
# Option A: point to the downloaded service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Option B: or provide the individual values below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep \n escaped in .env so the server can convert it to real newlines.
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n
